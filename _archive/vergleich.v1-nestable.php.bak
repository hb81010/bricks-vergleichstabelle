        $this->controls['expandBtnBorderWidth'] = [
            'tab'         => 'content',
            'group'       => 'expand',
            'label'       => esc_html__( 'Rahmen-Stärke', 'bricks-vergleich' ),
            'type'        => 'number',
            'units'       => true,
            'placeholder' => '2px',
            'required'    => [ 'expandEnabled', '=', true, 'expandButtonStyle', '!=', 'link' ],
