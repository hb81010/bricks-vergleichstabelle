            'type'     => 'checkbox',
            'default'  => true,
            'required' => [ 'expandEnabled', '=', true ],
        ];

        $this->controls['expandHoverBgColor'] = [
            'tab'      => 'content',
            'group'    => 'expand',
            'label'    => esc_html__( 'Hover-Hintergrund', 'bricks-vergleich' ),
            'type'     => 'color',
