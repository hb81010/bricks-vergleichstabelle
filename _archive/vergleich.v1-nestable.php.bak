            'type'     => 'separator',
            'label'    => esc_html__( 'Button-Größe & Abstand', 'bricks-vergleich' ),
            'required' => [ 'expandEnabled', '=', true ],
        ];

        $this->controls['expandBtnPadding'] = [
            'tab'      => 'content',
            'group'    => 'expand',
